    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import requests\\n\",\n",
    "    \"from bs4 import BeautifulSoup\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"def scrape_cim_data(url):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        response = requests.get(url)\\n\",\n",
    "    \"        response.raise_for_status()\\n\",\n",
    "    \"        soup = BeautifulSoup(response.text, 'html.parser')\\n\",\n",
    "    \"\\n\",\n",
    "    \"        data = {}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 1. Extract \\\"Fitxa tècnica\\\" data\\n\",\n",
    "    \"        # We look for the header 'Fitxa tècnica' and get its parent container\\n\",\n",
    "    \"        fitxa_header = soup.find('h4', string=lambda t: t and 'Fitxa tècnica' in t)\\n\",\n",
    "    \"        if fitxa_header:\\n\",\n",
    "    \"            container = fitxa_header.find_parent('div')\\n\",\n",
    "    \"            # The data is in pairs of col-6 divs\\n\",\n",
    "    \"            items = container.find_all('div', class_='col-6')\\n\",\n",
    "    \"\\n\",\n",
    "    \"            for i in range(0, len(items), 2):\\n\",\n",
    "    \"                if i + 1 < len(items):\\n\",\n",
    "    \"                    label = items[i].get_text(strip=True).replace(':', '')\\n\",\n",
    "    \"                    value = items[i+1].get_text(strip=True)\\n\",\n",
    "    \"                    data[label] = value\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 2. Check for \\\"Cim essencial\\\" flag\\n\",\n",
    "    \"        # It's inside a div with \\\"cim essencial\\\" text\\n\",\n",
    "    \"        essencial_flag = soup.find('strong', string=lambda t: t and 'Cim essencial' in t)\\n\",\n",
    "    \"        data['es_cim_essencial'] = essencial_flag is not None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 3. Bonus: Get the Peak Name (h1)\\n\",\n",
    "    \"        peak_name = soup.find('h1')\\n\",\n",
    "    \"        if peak_name:\\n\",\n",
    "    \"            data['nom_cim'] = peak_name.get_text(strip=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return data\\n\",\n",
    "    \"\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        return {\\\"error\\\": str(e)}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Example usage:\\n\",\n",
    "    \"cims_data_buff = []\\n\",\n",
    "    \"for _, c in tqdm(cims.iterrows(), total=cims.shape[0]):\\n\",\n",
    "    \"    cim_data = scrape_cim_data(c['url'])\\n\",\n",
    "    \"    cim_data_dict = dict(\\n\",\n",
    "    \"        **c.to_dict(),\\n\",\n",
    "    \"        **cim_data\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    cims_data_buff.append(cim_data_dict)\\n\",\n",
    "    \"\\n\",\n",
    "    \"cims_data = pd.DataFrame(cims_data_buff)\\n\",\n",
    "    \"cims_data\"\n",
    "   ],\n",
