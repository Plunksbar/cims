    "   \"source\": [\n",
    "    \"import requests\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import polyline # Install this to decode the geometry\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Your Origin\\n\",\n",
    "    \"origin = (41.415440142142046, 2.2055501155681494) # (lat, lon)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Mock data for demonstration (replace with your 522 locations)\\n\",\n",
    "    \"destinations = [{\\\"name\\\": \\\"Place A\\\", \\\"lat\\\": 41.38815007563826, \\\"lon\\\": 2.1295150741301136}]\\n\",\n",
    "    \"\\n\",\n",
    "    \"results = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for place in destinations:\\n\",\n",
    "    \"    # Changed 'overview=false' to 'overview=full'\\n\",\n",
    "    \"    url = f\\\"http://router.project-osrm.org/route/v1/driving/{origin[1]},{origin[0]};{place['lon']},{place['lat']}?overview=full&geometries=polyline\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    response = requests.get(url).json()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if response.get('code') == 'Ok':\\n\",\n",
    "    \"        route = response['routes'][0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # This is the encoded string representing the actual road path\\n\",\n",
    "    \"        encoded_path = route['geometry']\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Decode it into a list of (lat, lon) coordinates\\n\",\n",
    "    \"        decoded_path = polyline.decode(encoded_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        results.append({\\n\",\n",
    "    \"            \\\"Name\\\": place['name'],\\n\",\n",
    "    \"            \\\"Duration_Mins\\\": round(route['duration'] / 60, 2),\\n\",\n",
    "    \"            \\\"Distance_KM\\\": round(route['distance'] / 1000, 2),\\n\",\n",
    "    \"            \\\"Route_Geometry\\\": encoded_path, # Compact version for CSV\\n\",\n",
    "    \"            \\\"Coordinates\\\": decoded_path    # Full list for plotting\\n\",\n",
    "    \"        })\\n\",\n",
    "    \"\\n\",\n",
